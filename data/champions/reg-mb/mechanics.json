{
  "game": "Pokemon Champions",
  "regulation": "reg-mb",
  "regulation_name": "Regulation Set M-B",
  "description": "Battle mechanics for mid-battle damage and survival calculations in Pokemon Champions.",
  "format": {
    "battle_type": "doubles",
    "team_size": 6,
